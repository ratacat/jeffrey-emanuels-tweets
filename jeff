#!/usr/bin/env python3
"""jeff — Jeffrey Emanuel's Tweets. Search @doodlestein's tweet archive."""

import argparse
import html
import json
import os
import re
import shutil
import sqlite3
import subprocess
import sys
import textwrap

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
DEFAULT_DB = os.path.join(SCRIPT_DIR, "tweets.db")
INSTALLED_DB = os.path.expanduser("~/.local/share/jeff/tweets.db")


def get_db_path():
    for path in [DEFAULT_DB, INSTALLED_DB]:
        if os.path.exists(path):
            return path
    print("Error: tweets.db not found. Run the installer or set JEFF_DB.", file=sys.stderr)
    sys.exit(1)


def connect(db_path):
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    return conn


def find_fsfs():
    """Locate the fsfs binary. Check FSFS_PATH env, then PATH, then sibling build."""
    env_path = os.environ.get("FSFS_PATH")
    if env_path:
        return env_path if os.path.isfile(env_path) and os.access(env_path, os.X_OK) else None
    found = shutil.which("fsfs")
    if found:
        return found
    sibling = os.path.join(SCRIPT_DIR, "frankensearch", "target", "release", "fsfs")
    if os.path.isfile(sibling) and os.access(sibling, os.X_OK):
        return sibling
    return None


def get_corpus_dir():
    """Locate the corpus directory with .frankensearch index."""
    for d in [os.path.join(SCRIPT_DIR, "corpus"), os.path.expanduser("~/.local/share/jeff/corpus")]:
        if os.path.isdir(os.path.join(d, ".frankensearch")):
            return d
    return None


def strip_html(s):
    """Strip HTML tags and decode entities from fsfs snippets."""
    return html.unescape(re.sub(r"<[^>]+>", "", s))


def fsfs_search(fsfs_bin, corpus_dir, query, limit, as_json, db_path):
    """Run fsfs and enrich results with DB metadata. Returns True on success."""
    env = os.environ.copy()
    env["FSFS_INDEX_DIR"] = os.path.join(corpus_dir, ".frankensearch")
    try:
        proc = subprocess.run(
            [fsfs_bin, "search", query, "--format", "json", "--limit", str(limit)],
            capture_output=True, text=True, timeout=15, env=env, cwd=corpus_dir,
        )
        if proc.returncode != 0:
            return False
        result = json.loads(proc.stdout)
    except (subprocess.TimeoutExpired, json.JSONDecodeError, OSError):
        return False

    if not result.get("ok") or not result.get("data", {}).get("hits"):
        if as_json:
            print("[]")
        else:
            print(f"No tweets matching '{query}'")
        return True

    hits = result["data"]["hits"]
    tweet_ids = [os.path.splitext(h["path"])[0] for h in hits]

    # Enrich with DB metadata
    meta = {}
    try:
        conn = connect(db_path)
        placeholders = ",".join("?" * len(tweet_ids))
        rows = conn.execute(
            f"SELECT tweet_id, created_at, content, like_count, retweet_count, view_count "
            f"FROM tweets WHERE tweet_id IN ({placeholders})", tweet_ids,
        ).fetchall()
        meta = {str(r["tweet_id"]): dict(r) for r in rows}
    except Exception:
        pass

    if as_json:
        out = []
        for h in hits:
            tid = os.path.splitext(h["path"])[0]
            m = meta.get(tid, {})
            out.append({
                "tweet_id": tid,
                "created_at": m.get("created_at", ""),
                "content": m.get("content", strip_html(h.get("snippet", ""))),
                "like_count": m.get("like_count", 0),
                "retweet_count": m.get("retweet_count", 0),
                "view_count": m.get("view_count", 0),
                "score": h.get("score", 0),
                "search_engine": "frankensearch",
            })
        print(json.dumps(out, indent=2))
    else:
        for h in hits:
            tid = os.path.splitext(h["path"])[0]
            m = meta.get(tid, {})
            date = (m.get("created_at") or "")[:10]
            likes = m.get("like_count", 0)
            views = m.get("view_count", 0)
            content = m.get("content") or strip_html(h.get("snippet", ""))
            print(f"  {date}  {likes:>5} likes  {views:>7} views")
            for line in textwrap.wrap(content, width=90):
                print(f"    {line}")
            print()

    return True


def cmd_search_fts5(args):
    """FTS5 keyword search (fallback)."""
    conn = connect(args.db)
    use_json = getattr(args, "json", False)
    if use_json:
        rows = conn.execute(
            "SELECT t.tweet_id, t.created_at, t.content, t.like_count, t.retweet_count, "
            "t.view_count FROM tweets_fts fts JOIN tweets t ON t.id = fts.rowid "
            "WHERE tweets_fts MATCH ? ORDER BY rank LIMIT ?",
            (args.query, args.limit),
        ).fetchall()
        print(json.dumps([{**dict(r), "search_engine": "fts5"} for r in rows], indent=2))
    else:
        rows = conn.execute(
            "SELECT t.created_at, t.content, t.like_count, t.view_count "
            "FROM tweets_fts fts JOIN tweets t ON t.id = fts.rowid "
            "WHERE tweets_fts MATCH ? ORDER BY rank LIMIT ?",
            (args.query, args.limit),
        ).fetchall()
        if not rows:
            print(f"No tweets matching '{args.query}'")
            return
        for r in rows:
            date = (r["created_at"] or "")[:10]
            print(f"  {date}  {r['like_count']:>5} likes  {r['view_count'] or 0:>7} views")
            for line in textwrap.wrap(r["content"] or "", width=90):
                print(f"    {line}")
            print()


def cmd_search(args):
    use_json = getattr(args, "json", False)
    fsfs_bin = find_fsfs()
    corpus_dir = get_corpus_dir()
    if fsfs_bin and corpus_dir:
        if fsfs_search(fsfs_bin, corpus_dir, args.query, args.limit, use_json, args.db):
            return
        print("jeff: fsfs failed, falling back to keyword search", file=sys.stderr)
    elif not fsfs_bin:
        print("jeff: fsfs not found, using keyword search (install fsfs for hybrid search)", file=sys.stderr)
    cmd_search_fts5(args)


def cmd_top(args):
    conn = connect(args.db)
    col = {"likes": "like_count", "retweets": "retweet_count", "views": "view_count"}.get(
        args.sort, "like_count"
    )
    rows = conn.execute(
        f"SELECT created_at, content, like_count, retweet_count, view_count "
        f"FROM tweets WHERE is_retweet = 0 ORDER BY {col} DESC LIMIT ?",
        (args.limit,),
    ).fetchall()
    if args.json:
        print(json.dumps([dict(r) for r in rows], indent=2))
    else:
        for r in rows:
            date = (r["created_at"] or "")[:10]
            print(f"  {date}  {r['like_count']:>5} likes  {r['retweet_count']:>4} RTs  {r['view_count'] or 0:>7} views")
            for line in textwrap.wrap(r["content"] or "", width=90):
                print(f"    {line}")
            print()


def cmd_recent(args):
    conn = connect(args.db)
    rows = conn.execute(
        "SELECT created_at, content, like_count, view_count "
        "FROM tweets WHERE is_retweet = 0 ORDER BY created_at DESC LIMIT ?",
        (args.limit,),
    ).fetchall()
    if args.json:
        print(json.dumps([dict(r) for r in rows], indent=2))
    else:
        for r in rows:
            date = (r["created_at"] or "")[:16]
            print(f"  {date}  {r['like_count']:>5} likes  {r['view_count'] or 0:>7} views")
            for line in textwrap.wrap(r["content"] or "", width=90):
                print(f"    {line}")
            print()


def cmd_stats(args):
    conn = connect(args.db)
    c = conn.cursor()
    total = c.execute("SELECT COUNT(*) FROM tweets").fetchone()[0]
    original = c.execute("SELECT COUNT(*) FROM tweets WHERE is_retweet=0 AND is_reply=0").fetchone()[0]
    replies = c.execute("SELECT COUNT(*) FROM tweets WHERE is_reply=1").fetchone()[0]
    retweets = c.execute("SELECT COUNT(*) FROM tweets WHERE is_retweet=1").fetchone()[0]
    earliest = c.execute("SELECT MIN(created_at) FROM tweets").fetchone()[0]
    latest = c.execute("SELECT MAX(created_at) FROM tweets").fetchone()[0]
    avg_likes = c.execute("SELECT ROUND(AVG(like_count),1) FROM tweets WHERE is_retweet=0").fetchone()[0]
    avg_views = c.execute("SELECT ROUND(AVG(view_count),0) FROM tweets WHERE is_retweet=0").fetchone()[0]

    if args.json:
        print(json.dumps({
            "total": total, "original": original, "replies": replies,
            "retweets": retweets, "earliest": earliest, "latest": latest,
            "avg_likes": avg_likes, "avg_views": avg_views,
        }, indent=2))
    else:
        print(f"  @doodlestein (Jeffrey Emanuel) Tweet Archive")
        print(f"  {'='*45}")
        print(f"  Total tweets:    {total}")
        print(f"  Original:        {original}")
        print(f"  Replies:         {replies}")
        print(f"  Retweets:        {retweets}")
        print(f"  Date range:      {(earliest or '')[:10]} to {(latest or '')[:10]}")
        print(f"  Avg likes:       {avg_likes}")
        print(f"  Avg views:       {avg_views}")


def cmd_sql(args):
    conn = connect(args.db)
    rows = conn.execute(args.query).fetchall()
    if args.json or True:  # sql always outputs json
        print(json.dumps([dict(r) for r in rows], indent=2))


def main():
    parser = argparse.ArgumentParser(
        prog="jeff",
        description="Jeffrey Emanuel's Tweets — search @doodlestein's archive",
    )
    parser.add_argument("--db", default=os.environ.get("JEFF_DB", get_db_path()), help="Path to tweets.db")
    parser.add_argument("--json", action="store_true", help="Output as JSON (useful for agents)")
    sub = parser.add_subparsers(dest="command", required=True)

    p_search = sub.add_parser("search", help="Full-text search tweets")
    p_search.add_argument("query", help="Search query (FTS5 syntax)")
    p_search.add_argument("-n", "--limit", type=int, default=10)
    p_search.add_argument("--json", action="store_true", help="Output as JSON")

    p_top = sub.add_parser("top", help="Top tweets by engagement")
    p_top.add_argument("-s", "--sort", choices=["likes", "retweets", "views"], default="likes")
    p_top.add_argument("-n", "--limit", type=int, default=10)
    p_top.add_argument("--json", action="store_true", help="Output as JSON")

    p_recent = sub.add_parser("recent", help="Most recent tweets")
    p_recent.add_argument("-n", "--limit", type=int, default=10)
    p_recent.add_argument("--json", action="store_true", help="Output as JSON")

    p_stats = sub.add_parser("stats", help="Archive statistics")
    p_stats.add_argument("--json", action="store_true", help="Output as JSON")

    p_sql = sub.add_parser("sql", help="Run raw SQL query")
    p_sql.add_argument("query", help="SQL query")
    p_sql.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()
    {"search": cmd_search, "top": cmd_top, "recent": cmd_recent, "stats": cmd_stats, "sql": cmd_sql}[args.command](args)


if __name__ == "__main__":
    main()
